<?xml version="1.0" encoding="utf-8"?>
<!--
    Debug-only network security config.
    Trusts user-installed CA certificates (for Caddy's self-signed TLS in full-stack tests).
    NOT included in release builds.
-->
<network-security-config>
    <base-config>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
</network-security-config>
