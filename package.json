{
  "name": "ocr-hash-verifier",
  "version": "1.0.0",
  "description": "Live Verify: select claims on screen, or scan them on paper — both with quick mathematical verification",
  "scripts": {
    "test": "npm run test:unit && npm run test:playwright",
    "test:unit": "jest",
    "test:playwright": "playwright test",
    "build": "webpack",
    "serve": "cd public && python3 -m http.server 8000",
    "sync-shared": "node scripts/sync-shared.js",
    "transpile-normalize": "node scripts/transpile-normalize.js",
    "lint": "eslint public/**/*.js __tests__/**/*.js",
    "lint:fix": "eslint --fix public/**/*.js __tests__/**/*.js"
  },
  "keywords": [
    "ocr",
    "verification",
    "hash",
    "audit"
  ],
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "glob": "^13.0.0",
    "psl": "^1.15.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@eslint/js": "^9.38.0",
    "@playwright/test": "^1.49.0",
    "browserify": "^17.0.1",
    "eslint": "^9.38.0",
    "globals": "^16.4.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.2.0",
    "jsdom": "^27.0.1",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.1"
  }
}
